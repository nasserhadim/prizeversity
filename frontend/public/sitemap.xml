<?xml version="1.0" encoding="UTF-8"?>
<!--
  SITEMAP REFERENCE
  - priority (0.0–1.0): Relative importance of pages on the site (does not affect ranking vs other sites).
  - changefreq: Hint to crawlers how often content changes (weekly, monthly, yearly).
  - Google mostly ignores priority & changefreq as they use their own algorithms; the main value is listing the pages so nothing gets missed.
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
